{
  "name": "mongodb-postgresql",
  "version": "1.0.0",
  "description": "MongoDB driver compatibility layer backed by PostgreSQL",
  "main": "index.js",
  "scripts": {
    "test": "node --test test/[!i]*.test.js",
    "test:integration": "node --test test/integration*.test.js",
    "test:all": "node --test test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/[!i]*.test.js",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down -v",
    "test:docker": "npm run docker:up && npm run test:integration; npm run docker:down",
    "bench:pg": "node benchmark/run.js --pg postgresql://testuser:testpass@localhost:5433/testdb",
    "bench:mongo": "node benchmark/run.js --mongo mongodb://localhost:27017/benchmark",
    "bench:compare": "node benchmark/run.js --pg postgresql://testuser:testpass@localhost:5433/testdb --mongo mongodb://localhost:27017/benchmark"
  },
  "keywords": [
    "mongodb",
    "postgresql",
    "compatibility",
    "driver"
  ],
  "license": "MIT",
  "dependencies": {
    "pg": "^8.11.0",
    "pg-cursor": "^2.10.0"
  },
  "devDependencies": {
    "mongodb": "^7.1.1"
  }
}
